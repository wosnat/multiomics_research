{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__multiomics-kg__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/log-mcp-usage.sh",
            "statusMessage": "Logging MCP tool usage"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "mcp__multiomics-kg__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/log-mcp-usage.sh",
            "statusMessage": "Logging MCP tool failure"
          }
        ]
      }
    ]
  }
}
